# --- Precomputed tables and run artifacts ---
# Tables are large, regenerated by scripts/build_*.py, and managed
# manually (uploaded out-of-band or via release attachments). Do not
# track them in git. To check a specific table in anyway, force-add:
#   git add -f tables_data/foo.pkl
artifacts/
tables_data/
*.pkl
*.npy
*.npz
opening_build*.log
opening_build*.pid

# --- Build logs ---
logs/
*.log
nohup.out

# --- Profiling output ---
*.prof
*.lprof
*.profraw

# --- OS junk ---
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Local secrets ---
.env
.env.local
*.local

